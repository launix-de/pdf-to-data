{
  "name": "launix-de/pdf-to-data",
  "description": "Reusable PDF extraction library for normalized HTML, positioned elements, and sales-document parsing.",
  "type": "library",
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "smalot/pdfparser": "^2.12"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Launix\\PdfToData\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Launix\\PdfToData\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/pdf-to-data"
  ],
  "scripts": {
    "test": "phpunit"
  }
}
